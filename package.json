{
  "name": "srm-dental-web-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build:client": "npm run build --workspace=client",
    "build:vercel": "npm run build --workspace=client",
    "build:render": "npm run build --workspace=client",
    "start:render": "npm start --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "react-chartjs-2": "^5.3.1",
    "recharts": "^3.7.0"
  }
}
